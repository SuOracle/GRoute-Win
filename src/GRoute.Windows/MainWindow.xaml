                        <TextBlock Text="{DynamicResource Str.check_update}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <CheckBox x:Name="LangToggle" Style="{StaticResource ToggleSwitch}" Click="LangToggle_Click" Margin="10,6,10,6" Padding="4,4">
                    <StackPanel Orientation="Horizontal">
