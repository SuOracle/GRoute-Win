                                <CheckBox x:Name="SniffMaster" Style="{StaticResource ToggleSwitch}" Content="{DynamicResource Str.sniffing}"
                                          Click="SniffMaster_Click"/>
                                <StackPanel x:Name="SniffOptions" Margin="0,12,0,0">
                                    <WrapPanel>
                                        <CheckBox x:Name="SniffTls" Style="{StaticResource CheckChip}" Content="TLS" Margin="0,0,8,8" Click="SniffChanged"/>
                                        <CheckBox x:Name="SniffHttp" Style="{StaticResource CheckChip}" Content="HTTP" Margin="0,0,8,8" Click="SniffChanged"/>
                                        <CheckBox x:Name="SniffQuic" Style="{StaticResource CheckChip}" Content="QUIC" Margin="0,0,8,8" Click="SniffChanged"/>
                                        <CheckBox x:Name="SniffFakeDns" Style="{StaticResource CheckChip}" Content="FakeDNS" Margin="0,0,8,8" Click="SniffChanged"/>
                                    </WrapPanel>
                                    <CheckBox x:Name="RouteOnlyToggle" Style="{StaticResource ToggleSwitch}" Content="{DynamicResource Str.route_only}"
                                              FontSize="12.5" Margin="0,4,0,0" Click="RouteOnly_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ToolCard}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Str.mixed_port}" Foreground="#9FB3D6" FontSize="12" Margin="0,0,0,9"
                                           FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend, Segoe UI"/>
                                <Border CornerRadius="9" Background="#0A1428" BorderBrush="#2A3A63" BorderThickness="1.3" Padding="12,0" Width="130" HorizontalAlignment="Left" Height="38">
                                    <TextBox x:Name="MixedPortBox" Background="Transparent" BorderThickness="0" Foreground="White"
                                             VerticalContentAlignment="Center" FontSize="13.5" CaretBrush="#6E9CF0" MaxLength="5"
                                             FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend, Segoe UI"
                                             TextChanged="MixedPort_Changed" FlowDirection="LeftToRight"/>
                                </Border>
                                <TextBlock x:Name="MixedPortHint" Text="{DynamicResource Str.port_invalid}" Foreground="#E0575C" FontSize="11" Margin="0,6,0,0"
                                           Visibility="Collapsed" FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend, Segoe UI"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ToolCard}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Str.log_level}" Foreground="#9FB3D6" FontSize="12" Margin="0,0,0,10"
                                           FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend, Segoe UI"/>
                                <Border CornerRadius="10" Background="#0A1428" BorderBrush="#284372" BorderThickness="1" Padding="4" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="LogNone" GroupName="LogLevel" Style="{StaticResource SegRadio}" Content="{DynamicResource Str.log_none}" Tag="none" Click="LogLevel_Set" Margin="0,0,3,0"/>
