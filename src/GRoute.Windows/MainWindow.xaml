<Window x:Class="GRoute.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        xmlns:local="clr-namespace:GRoute.Windows"
        xmlns:Primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="GRoute" Height="436" Width="484" Icon="GRoute.ico"
        WindowStartupLocation="CenterScreen"
        FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend, Segoe UI" ResizeMode="NoResize">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#22396B" Offset="0"/>
            <GradientStop Color="#13234A" Offset="0.5"/>
            <GradientStop Color="#0A1631" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="42" CornerRadius="10" GlassFrameThickness="1" ResizeBorderThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:FlagConverter x:Key="FlagConv"/>
        <local:FlagNameConverter x:Key="FlagNameConv"/>
        <local:PingBrushConverter x:Key="PingBrush"/>
        <local:PingGlowConverter x:Key="PingGlow"/>
