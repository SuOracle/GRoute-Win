                                <TextBlock Text="{DynamicResource Str.mode_system}" Foreground="White" FontSize="13.5" FontWeight="SemiBold"
                                           FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend SemiBold, Segoe UI"/>
                                <TextBlock Text="{DynamicResource Str.mode_system_d}" Foreground="#8FA3C8" FontSize="11"/>
                            </StackPanel>
                            <Path Grid.Column="2" x:Name="QSCheckSystem" Data="M2 7 L6 11 L14 2" Stroke="#2FDF8F" StrokeThickness="2.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Fill="Transparent" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="10,0,4,0"/>
                        </Grid>
                    </Button>
