                                                                  VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                                    <Button x:Name="PART_Button" Grid.Column="1" Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" Focusable="False" Width="26" Height="26" FocusVisualStyle="{x:Null}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" CornerRadius="6" Background="Transparent">
                                                    <Path Data="M3 3 H15 V15 H3 Z M3 7 H15 M6 1.5 V4.5 M12 1.5 V4.5"
                                                          Stroke="#8FA3C8" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                          Fill="Transparent" Width="15" Height="15" Stretch="Uniform"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#1E3566"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom" PopupAnimation="Fade" StaysOpen="False"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="QSRow" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="QSScale" ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <Border x:Name="Hov" CornerRadius="10" Background="#1A2743" Opacity="0"/>
                            <Border Padding="9,6"><ContentPresenter/></Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Hov" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.17"/>
                                    </Storyboard></BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Hov" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.22"/>
                                    </Storyboard></BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Hov" Property="Background" Value="#253961"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="QSScale" Storyboard.TargetProperty="ScaleX" To="0.97" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetName="QSScale" Storyboard.TargetProperty="ScaleY" To="0.93" Duration="0:0:0.08"/>
                                    </Storyboard></BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="QSScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.4"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="QSScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.4"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard></BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InlineEdit" TargetType="TextBox">
            <Setter Property="Background" Value="#0B1830"/>
            <Setter Property="BorderBrush" Value="#3D6AD6"/>
            <Setter Property="BorderThickness" Value="1.4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="#6E9CF0"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#0E1A38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="#6E9CF0"/>
            <Setter Property="BorderBrush" Value="#2A3A63"/>
            <Setter Property="BorderThickness" Value="1.3"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="pack://application:,,,/GRoute;component/Fonts/#Lexend, Segoe UI"/>
            <Setter Property="Padding" Value="11,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" CornerRadius="9" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3D6AD6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FormComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#DCE6F5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="pack://application:,,,/GRoute;component/Fonts/#Lexend, Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" CornerRadius="6" Background="Transparent" Padding="11,8" Margin="3,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E3566"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#6E9CF0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FormCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="pack://application:,,,/GRoute;component/Fonts/#Lexend, Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource FormComboItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd" CornerRadius="9" Background="#0E1A38" BorderBrush="#2A3A63" BorderThickness="1.3">
                                            <Path Data="M1 3 L5 7 L9 3" Stroke="#8FA3C8" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Width="11" Height="7" Stretch="Uniform" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3D6AD6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False" Margin="11,0,32,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade" Focusable="False">
                                <Border x:Name="DropBorder" CornerRadius="9" Background="#12213F" BorderBrush="#2A3C64" BorderThickness="1" Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" RenderTransformOrigin="0.5,0">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="DropSlide"/>
                                    </Border.RenderTransform>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="DropSlide" Storyboard.TargetProperty="Y" From="-8" To="0" Duration="0:0:0.16">
                                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                    <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="14" ShadowDepth="3" Opacity="0.5"/></Border.Effect>
                                    <ScrollViewer x:Name="DropScroll" MaxHeight="220">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="IconAction" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="ToolTipService.IsEnabled" Value="False"/>
            <Setter Property="Foreground" Value="#F2F7FF"/>
            <EventSetter Event="MouseEnter" Handler="IconActionEnter"/>
            <EventSetter Event="MouseLeave" Handler="IconActionLeave"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <Border x:Name="Neon" CornerRadius="9" Background="{TemplateBinding BorderBrush}" Opacity="0" SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="Glow" Color="{Binding BorderBrush.Color, RelativeSource={RelativeSource TemplatedParent}}" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                </Border.Effect>
                            </Border>
                            <Grid ClipToBounds="True">
                                <TextBlock x:Name="Label" Text="{TemplateBinding ToolTip}" Opacity="0" Foreground="{TemplateBinding Foreground}"
                                           FontSize="12" FontWeight="SemiBold" FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend SemiBold, Segoe UI"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ContentPresenter x:Name="Icon" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Neon" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="0.75" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="BlurRadius" To="14" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="Icon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="Label" Storyboard.TargetProperty="Opacity" To="1" BeginTime="0:0:0.1" Duration="0:0:0.16"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Neon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="BlurRadius" To="0" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetName="Label" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="Icon" Storyboard.TargetProperty="Opacity" To="1" BeginTime="0:0:0.08" Duration="0:0:0.16"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX" To="0.86" Duration="0:0:0.09"/>
                                            <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY" To="0.86" Duration="0:0:0.09"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="pack://application:,,,/GRoute;component/Fonts/#Lexend, Segoe UI"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#8FB4F0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Grid Width="14" Height="14" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <ScaleTransform x:Name="BoxScale" ScaleX="1" ScaleY="1"/>
                                </Grid.RenderTransform>
                                <Border x:Name="BoxBg" CornerRadius="5" Background="#22102547" BorderThickness="1.6">
                                    <Border.BorderBrush>
                                        <SolidColorBrush x:Name="BoxStroke" Color="#B36E9CF0"/>
                                    </Border.BorderBrush>
                                    <Border.Effect>
                                        <DropShadowEffect x:Name="BoxGlow" Color="#6E9CF0" BlurRadius="9" ShadowDepth="0" Opacity="0.22"/>
                                    </Border.Effect>
                                </Border>
                                <Border x:Name="Fill" CornerRadius="3.5" Opacity="0" RenderTransformOrigin="0.5,0.5">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#6E9CF0" Offset="0"/>
                                            <GradientStop Color="#8FE3FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="FillScale" ScaleX="0" ScaleY="0"/>
                                    </Border.RenderTransform>
                                </Border>
                                <Path x:Name="CheckMark" Data="M 3.2,7 L 5.9,9.8 L 10.5,3.8"
                                      Stroke="#0E1A38" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" Fill="Transparent" Opacity="0" RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="CheckScale" ScaleX="0" ScaleY="0"/>
                                            <RotateTransform x:Name="CheckRot" Angle="-90"/>
                                        </TransformGroup>
                                    </Path.RenderTransform>
                                </Path>
                            </Grid>
                            <ContentPresenter x:Name="Lbl" VerticalAlignment="Center" Margin="8,0,0,0"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BoxGlow" Storyboard.TargetProperty="Opacity" To="0.75" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="BoxGlow" Storyboard.TargetProperty="BlurRadius" To="16" Duration="0:0:0.25"/>
                                    </Storyboard></BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BoxGlow" Storyboard.TargetProperty="Opacity" To="0.25" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="BoxGlow" Storyboard.TargetProperty="BlurRadius" To="9" Duration="0:0:0.25"/>
                                    </Storyboard></BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Fill" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
                                        <DoubleAnimation Storyboard.TargetName="FillScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.6"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="FillScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.6"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="CheckMark" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2" BeginTime="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="CheckScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.4" BeginTime="0:0:0.12">
                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.7"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="CheckScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.4" BeginTime="0:0:0.12">
                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.7"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="CheckRot" Storyboard.TargetProperty="Angle" To="0" Duration="0:0:0.45" BeginTime="0:0:0.12">
                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="BoxScale" Storyboard.TargetProperty="ScaleX" To="0.9" Duration="0:0:0.2" AutoReverse="True"/>
                                        <DoubleAnimation Storyboard.TargetName="BoxScale" Storyboard.TargetProperty="ScaleY" To="0.9" Duration="0:0:0.2" AutoReverse="True"/>
                                        <ColorAnimation Storyboard.TargetName="BoxStroke" Storyboard.TargetProperty="Color" To="#6E9CF0" Duration="0:0:0.2"/>
                                    </Storyboard></BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="CheckMark" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="CheckScale" Storyboard.TargetProperty="ScaleX" To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="CheckScale" Storyboard.TargetProperty="ScaleY" To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="CheckRot" Storyboard.TargetProperty="Angle" To="-90" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="Fill" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="FillScale" Storyboard.TargetProperty="ScaleX" To="0" Duration="0:0:0.3"/>
                                        <DoubleAnimation Storyboard.TargetName="FillScale" Storyboard.TargetProperty="ScaleY" To="0" Duration="0:0:0.3"/>
                                        <ColorAnimation Storyboard.TargetName="BoxStroke" Storyboard.TargetProperty="Color" To="#B36E9CF0" Duration="0:0:0.25"/>
                                    </Storyboard></BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BoxBg" Property="Opacity" Value="0.4"/>
                                <Setter TargetName="Lbl" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0E1A38" CornerRadius="10,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Image Source="GRouteSmall.png" Height="24" HorizontalAlignment="Left"
                       VerticalAlignment="Center" Margin="14,0,0,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button Style="{StaticResource TitleBarButton}" Click="TitleMin_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True" Margin="0,0,2,0">
                        <Path Data="M 0,0 H 11" Stroke="#C9D6EE" StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Button>
                    <Button Style="{StaticResource TitleCloseButton}" Click="TitleClose_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path Data="M 0,0 L 10,10 M 10,0 L 0,10" Stroke="#C9D6EE" StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ParticleHost" Grid.Row="1" IsHitTestVisible="False" ClipToBounds="True"/>

        <Grid Grid.Row="1" Margin="16,8,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="HeaderRow" Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="MenuButton" Click="ToggleMainMenu" Width="30" Height="30"
                    Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"
                    Margin="2,0,0,0" FocusVisualStyle="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SetBg" CornerRadius="7" Background="Transparent" BorderBrush="#9FB3D6" BorderThickness="2" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="MenuScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid Width="16" Height="6" Margin="0,0,0,2">
                                    <Rectangle Width="16" Height="2" Fill="#E3EBFA" RadiusX="1" RadiusY="1" VerticalAlignment="Center"/>
                                    <Ellipse Width="5" Height="5" Fill="#6E9CF0" Stroke="White" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse.Effect><DropShadowEffect Color="White" BlurRadius="3.5" ShadowDepth="0"/></Ellipse.Effect>
                                        <Ellipse.RenderTransform><TranslateTransform x:Name="Knob1T" X="-4.5"/></Ellipse.RenderTransform>
