                            <TextBlock Text="{DynamicResource Str.conn_settings}" Foreground="White" FontSize="17" FontWeight="Bold"
                                       FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend Bold, Segoe UI" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Visibility="Collapsed" Height="0">
                            <RadioButton x:Name="ModeProxy" GroupName="ConnMode" IsChecked="True"/>
                            <RadioButton x:Name="ModeTun" GroupName="ConnMode"/>
