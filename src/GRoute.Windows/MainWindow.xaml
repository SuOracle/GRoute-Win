                    <TextBlock Text="GRoute" Foreground="White" FontSize="26" FontWeight="Bold" FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend Bold, Segoe UI"
                               HorizontalAlignment="Center" Margin="0,12,0,4"/>
