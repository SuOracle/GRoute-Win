                        <Path Data="M14.7,3.3 C15.1,4.8 14.7,6.4 13.6,7.5 C12.5,8.6 10.9,9 9.4,8.6 L4,14 L2,12 L7.4,6.6 C7,5.1 7.4,3.5 8.5,2.4 C9.6,1.3 11.2,0.9 12.7,1.3 L10.2,3.8 L12.2,5.8 Z" Fill="#C9D6EE" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="{DynamicResource Str.nav_tools}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="MenuItemAbout" Style="{StaticResource MenuItemBtn}" Click="MenuGo_About">
