                    </Button>
                </Grid>

                <Grid Grid.Row="3" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Path Data="M2,3 H14 V6.5 H2 Z M2,9.5 H14 V13 H2 Z M4,4.75 h0.01 M4,11.25 h0.01"
                              Stroke="#9FB3D6" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              StrokeLineJoin="Round" Fill="Transparent" Width="16" Height="16" Stretch="Uniform"
                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource Str.servers}" Foreground="#C7D4EC" FontSize="15"
                                   FontWeight="SemiBold" FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend SemiBold, Segoe UI" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Grid Grid.Column="1" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Button x:Name="SearchToggle" Style="{StaticResource IconAction}" Click="OpenSearch_Click"
                                ToolTip="{DynamicResource Str.search}" BorderBrush="#3C5A8C">
                            <Path Data="M10 16 A6 6 0 1 1 10 4 A6 6 0 1 1 10 16 M14.8 14.8 L19 19" Stroke="#8FA3C8" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Width="17" Height="17" Stretch="Uniform"/>
                        </Button>
                        <Border x:Name="SearchBox" Height="30" Width="0" CornerRadius="9" Background="#0E1A38" BorderBrush="#3D6AD6"
                                BorderThickness="1.4" ClipToBounds="True" Visibility="Collapsed" HorizontalAlignment="Left">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Data="M10 16 A6 6 0 1 1 10 4 A6 6 0 1 1 10 16 M14.8 14.8 L19 19" Stroke="#6E9CF0" StrokeThickness="1.7"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBox x:Name="SearchInput" Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="#EAF2FF"
                                         CaretBrush="#6E9CF0" FontSize="12.5" FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend, Segoe UI" MinWidth="118" VerticalContentAlignment="Center" TextChanged="SearchChanged"/>
                                <Button Grid.Column="2" x:Name="SearchClear" Width="30" Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" FocusVisualStyle="{x:Null}" Click="CloseSearch_Click" Margin="0,0,3,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent" CornerRadius="7">
                                                <Path x:Name="X" Data="M5 5 L15 15 M15 5 L5 15" Stroke="#7E93B8" StrokeThickness="1.7"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="13" Height="13" Stretch="Uniform"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="X" Property="Stroke" Value="#E0575C"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                    <Grid Grid.Column="2" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Button x:Name="SortButton" Style="{StaticResource IconAction}" Click="SortButton_Click"
                                ToolTip="{DynamicResource Str.sort}" BorderBrush="#3C5A8C">
                            <Path Data="M4 6h16 M4 12h10 M4 18h6" Stroke="#8FA3C8" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"
                                  Width="17" Height="17" Stretch="Uniform"/>
                        </Button>
                        <Popup x:Name="SortPopup" PlacementTarget="{Binding ElementName=SortButton}" Placement="Bottom"
                               AllowsTransparency="True" StaysOpen="True" PopupAnimation="Fade" HorizontalOffset="0" VerticalOffset="4">
                            <Border Background="#12213F" BorderBrush="#2A3C64" BorderThickness="1" CornerRadius="10" Padding="4"
                                    MinWidth="140">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="3" Opacity="0.5"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Button x:Name="SortAddedItem" Style="{StaticResource LiveButton}" Click="SortAdded_Click"
                                            Background="Transparent" BorderThickness="0" Foreground="#DCE6F5" Height="34"
                                            Padding="10,0" HorizontalContentAlignment="Left" Cursor="Hand">
                                        <StackPanel Orientation="Horizontal">
                                            <Path x:Name="AddedCheck" Data="M2,7 L5.5,10.5 L12,3" Stroke="#6E9CF0" StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                  Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,9,0" Opacity="1"/>
                                            <TextBlock Text="{DynamicResource Str.sort_added}" VerticalAlignment="Center" FontSize="12.5"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="SortFastestItem" Style="{StaticResource LiveButton}" Click="SortFastest_Click"
                                            Background="Transparent" BorderThickness="0" Foreground="#DCE6F5" Height="34"
                                            Padding="10,0" HorizontalContentAlignment="Left" Cursor="Hand">
                                        <StackPanel Orientation="Horizontal">
                                            <Path x:Name="FastestCheck" Data="M2,7 L5.5,10.5 L12,3" Stroke="#6E9CF0" StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                  Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,9,0" Opacity="0"/>
                                            <TextBlock Text="{DynamicResource Str.sort_fastest}" VerticalAlignment="Center" FontSize="12.5"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="SortAlphaItem" Style="{StaticResource LiveButton}" Click="SortAlpha_Click"
                                            Background="Transparent" BorderThickness="0" Foreground="#DCE6F5" Height="34"
                                            Padding="10,0" HorizontalContentAlignment="Left" Cursor="Hand">
                                        <StackPanel Orientation="Horizontal">
                                            <Path x:Name="AlphaCheck" Data="M2,7 L5.5,10.5 L12,3" Stroke="#6E9CF0" StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                  Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,9,0" Opacity="0"/>
                                            <TextBlock Text="{DynamicResource Str.sort_alpha}" VerticalAlignment="Center" FontSize="12.5"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <Button x:Name="TestAllButton" Grid.Column="3" Cursor="Hand" Click="TestAll_Click"
                            Background="Transparent" BorderThickness="0" FocusVisualStyle="{x:Null}"
                            MouseEnter="TestAllHoverEnter" MouseLeave="TestAllHoverLeave">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Outer" CornerRadius="13" Padding="2" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="TestPressScale" ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop x:Name="OuterA" Color="#6E6E9CF0" Offset="0"/>
                                            <GradientStop x:Name="OuterB" Color="#386E9CF0" Offset="0.5"/>
                                            <GradientStop Color="#1A6E9CF0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border x:Name="OuterGlow" CornerRadius="11" Background="#0E1A38">
                                        <Border.Effect>
                                            <DropShadowEffect x:Name="TestGlow" Color="#6E9CF0" BlurRadius="12" ShadowDepth="0" Opacity="0"/>
                                        </Border.Effect>
                                        <StackPanel Orientation="Horizontal" Margin="14,6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path Data="M8.5,1 L3,9 H7.5 L6.5,15 L13,6.5 H8 Z"
                                                  Fill="#EAF2FF" Width="13" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock x:Name="TestAllText" Text="{DynamicResource Str.test_all}" Foreground="White"
                                                       FontSize="12" FontWeight="SemiBold" FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend SemiBold, Segoe UI" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="TestPressScale" Storyboard.TargetProperty="ScaleX" To="0.93" Duration="0:0:0.09"/>
                                                    <DoubleAnimation Storyboard.TargetName="TestPressScale" Storyboard.TargetProperty="ScaleY" To="0.93" Duration="0:0:0.09"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="TestPressScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.18">
                                                        <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetName="TestPressScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.18">
                                                        <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" MaxHeight="360"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Style="{StaticResource EdgeShift}"
                              x:Name="GroupScroll" CanContentScroll="False" FocusVisualStyle="{x:Null}">
                    <ItemsControl x:Name="GroupList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel x:Name="GroupItem" Margin="0,0,0,14">
                                    <Border x:Name="HeaderBox" CornerRadius="12" Cursor="Hand" Background="#102547" BorderBrush="#35548C" BorderThickness="2"
                                            MouseLeftButtonUp="ToggleGroup" PreviewMouseLeftButtonDown="RowPressDown" PreviewMouseLeftButtonUp="RowPressUp" MouseLeave="RowLeave" Tag="{Binding Id}" RenderTransformOrigin="0.5,0.5">
                                        <Grid>
                                            <Border x:Name="HoverFill" CornerRadius="12" Background="#2A4A82" Opacity="0"/>
                                            <StackPanel Margin="12,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Path Grid.Column="0" Data="M 0,0 L 6,6 L 0,12" Stroke="#9FB3D6" StrokeThickness="3"
                                                          Visibility="{Binding SubActionsVisible, Converter={StaticResource BoolToVis}}"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                          Stretch="None" VerticalAlignment="Center" Margin="2,0,12,0" RenderTransformOrigin="0.5,0.5">
                                                        <Path.RenderTransform><RotateTransform x:Name="GroupChevronRot" Angle="0"/></Path.RenderTransform>
                                                        <Path.Style>
                                                            <Style TargetType="Path">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                        <DataTrigger.EnterActions>
                                                                            <BeginStoryboard><Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="90" Duration="0:0:0.2"/>
                                                                            </Storyboard></BeginStoryboard>
                                                                        </DataTrigger.EnterActions>
                                                                        <DataTrigger.ExitActions>
                                                                            <BeginStoryboard><Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="0" Duration="0:0:0.2"/>
                                                                            </Storyboard></BeginStoryboard>
                                                                        </DataTrigger.ExitActions>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Path.Style>
                                                    </Path>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <Grid>
                                                            <TextBlock x:Name="SubName" Text="{Binding Name}" Foreground="White" FontSize="13"
                                                                       FontWeight="SemiBold" FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend SemiBold, Segoe UI" TextTrimming="CharacterEllipsis"/>
                                                            <TextBox x:Name="SubNameEdit" Style="{StaticResource InlineEdit}" FontSize="12.5" FontWeight="SemiBold"
                                                                     FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend SemiBold, Segoe UI"
                                                                     Visibility="Collapsed" HorizontalAlignment="Left" MinWidth="150" KeyDown="RenameKeyDown" LostFocus="RenameCommit"/>
                                                        </Grid>
                                                        <TextBlock Text="{Binding UsageText}" Foreground="#9FB3D6" FontSize="11"
                                                                   FlowDirection="LeftToRight"
                                                                   Visibility="{Binding HasUsageText, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding CountText}" Foreground="#9FB3D6"
                                                               FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <Button Grid.Column="3" Style="{StaticResource IconAction}" Tag="{Binding Id}" ToolTip="{DynamicResource Str.rename}"
                                                            Click="RenameSub_Click" BorderBrush="#3D6AD6"
                                                            Visibility="{Binding SubActionsVisible, Converter={StaticResource BoolToVis}}">
                                                        <Path Data="M12 20h9 M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z" Stroke="#6E9CF0" StrokeThickness="1.8"
                                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                              Fill="Transparent" Width="16" Height="16" Stretch="Uniform"/>
                                                    </Button>
                                                    <Button Grid.Column="4" Style="{StaticResource IconAction}" Tag="{Binding Id}" ToolTip="{DynamicResource Str.copy}"
                                                            Click="CopySub_Click" BorderBrush="#3D6AD6"
                                                            Visibility="{Binding SubActionsVisible, Converter={StaticResource BoolToVis}}">
                                                        <Path Data="M20 9h-9a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2v-9a2 2 0 0 0-2-2z M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" Stroke="#6E9CF0" StrokeThickness="1.8"
                                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                              Fill="Transparent" Width="17" Height="17" Stretch="Uniform"/>
                                                    </Button>
                                                    <Button Grid.Column="5" Style="{StaticResource IconAction}" Tag="{Binding Id}" ToolTip="{DynamicResource Str.refresh}"
                                                            Click="RefreshSub_Click" BorderBrush="#3D6AD6"
                                                            Visibility="{Binding SubActionsVisible, Converter={StaticResource BoolToVis}}">
                                                        <Path Data="M23 4v6h-6 M1 20v-6h6 M3.51 9a9 9 0 0 1 14.85-3.36L23 10 M1 14l4.64 4.36A9 9 0 0 0 20.49 15" Stroke="#6E9CF0" StrokeThickness="1.8"
                                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                              Fill="Transparent" Width="17" Height="17" Stretch="Uniform"/>
                                                    </Button>
                                                    <Button Grid.Column="6" Style="{StaticResource IconAction}" Tag="{Binding Id}" ToolTip="{DynamicResource Str.remove}"
                                                            Click="RemoveSub_Click" BorderBrush="#E0575C"
                                                            Visibility="{Binding SubActionsVisible, Converter={StaticResource BoolToVis}}">
                                                        <Path Data="M3 6h18 M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 M10 11v6 M14 11v6" Stroke="#E57373" StrokeThickness="1.8"
                                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                              Fill="Transparent" Width="17" Height="17" Stretch="Uniform"/>
                                                    </Button>
                                                </Grid>
                                                <Grid Height="4" Margin="0,8,0,0"
                                                      Visibility="{Binding HasUsageBar, Converter={StaticResource BoolToVis}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{Binding RemainingStar}"/>
                                                        <ColumnDefinition Width="{Binding UsedStar}"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="#3D6AD6" CornerRadius="2"/>
                                                    <Border Grid.Column="1" Background="#243456" CornerRadius="2"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <StackPanel x:Name="CfgContainer" Margin="0,0,0,0" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl ItemsSource="{Binding Configs}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border x:Name="CfgBox" CornerRadius="12" Margin="0,8,0,0" Cursor="Hand"
                                                            MouseLeftButtonUp="SelectConfig" PreviewMouseLeftButtonDown="RowPressDown" PreviewMouseLeftButtonUp="RowPressUp" MouseLeave="RowLeave" Tag="{Binding Id}"
                                                            RenderTransformOrigin="0.5,0.5">
                                                        <Border.RenderTransform>
                                                            <TranslateTransform/>
                                                        </Border.RenderTransform>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#0E1A38"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Background" Value="#1E3566"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Border x:Name="CfgHover" CornerRadius="12" Background="#274672" Opacity="0"/>
                                                            <Grid Margin="12,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid Grid.Column="0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Ellipse Grid.Column="0" Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,15,0"
                                                                         Fill="{Binding Ping, Converter={StaticResource PingBrush}}">
                                                                    <Ellipse.Effect>
                                                                        <DropShadowEffect Color="{Binding Ping, Converter={StaticResource PingGlow}}" BlurRadius="6" ShadowDepth="0" Opacity="0.85"/>
                                                                    </Ellipse.Effect>
                                                                    <Ellipse.Triggers>
                                                                        <EventTrigger RoutedEvent="Loaded">
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.BlurRadius)"
                                                                                                     From="4" To="13" Duration="0:0:1.15" AutoReverse="True" RepeatBehavior="Forever"/>
                                                                                    <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Effect).(DropShadowEffect.Opacity)"
                                                                                                     From="0.45" To="1" Duration="0:0:1.15" AutoReverse="True" RepeatBehavior="Forever"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </EventTrigger>
                                                                    </Ellipse.Triggers>
                                                                </Ellipse>
                                                                <Rectangle Grid.Column="1" Width="24" Height="18" RadiusX="3.5" RadiusY="3.5"
                                                                           VerticalAlignment="Center" Margin="0,0,14,0" SnapsToDevicePixels="True">
                                                                    <Rectangle.Fill>
                                                                        <ImageBrush ImageSource="{Binding Name, Converter={StaticResource FlagConv}}" Stretch="UniformToFill"
                                                                                    RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                    </Rectangle.Fill>
                                                                    <Rectangle.Style>
                                                                        <Style TargetType="Rectangle">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Name, Converter={StaticResource FlagConv}}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Rectangle.Style>
                                                                </Rectangle>
                                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                                    <Grid x:Name="NameClip" ClipToBounds="True" HorizontalAlignment="Stretch" Margin="0,0,12,0" SizeChanged="NameClip_SizeChanged">
                                                                        <Canvas Height="20" VerticalAlignment="Center" RenderTransformOrigin="0,0.5">
                                                                            <Canvas.RenderTransform>
                                                                                <TranslateTransform x:Name="NameShift" X="0"/>
                                                                            </Canvas.RenderTransform>
