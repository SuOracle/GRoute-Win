                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="ManualPanel" Visibility="Collapsed" VerticalAlignment="Top">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource LiveButton}" Grid.Column="0" Click="CloseManual"
                            Background="Transparent" BorderThickness="0" Padding="6,4" Cursor="Hand" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Path Data="M 8,0 L 0,7 L 8,14" Stroke="#9FB3D6" StrokeThickness="3"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Stretch="None"/>
                    </Button>
                    <TextBlock Grid.Column="1" x:Name="ManualTitle" Text="{DynamicResource Str.add_manually}" Foreground="White" FontSize="16" FontWeight="SemiBold" FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend SemiBold, Segoe UI" VerticalAlignment="Center"/>
                </Grid>

                <ScrollViewer Style="{StaticResource EdgeShift}" x:Name="ManualScroll" Grid.Row="1" ScrollChanged="ManualScroll_ScrollChanged" VerticalScrollBarVisibility="Auto" CanContentScroll="False" FocusVisualStyle="{x:Null}">
                    <StackPanel>
                        <TextBlock Text="Name (optional)" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                        <TextBox x:Name="MName" Style="{StaticResource FormInput}"/>
                        <TextBlock Text="Protocol" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                        <ComboBox x:Name="MProtocol" Style="{StaticResource FormCombo}" SelectionChanged="FieldSel_Changed">
                            <sys:String>vless</sys:String>
                            <sys:String>vmess</sys:String>
                            <sys:String>trojan</sys:String>
                            <sys:String>shadowsocks</sys:String>
                            <sys:String>socks</sys:String>
                            <sys:String>http</sys:String>
                            <sys:String>wireguard</sys:String>
                        </ComboBox>
                        <TextBlock Text="Address" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                        <TextBox x:Name="MAddress" Style="{StaticResource FormInput}"/>
                        <TextBlock Text="Port" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                        <TextBox x:Name="MPort" Style="{StaticResource FormInput}"/>
                        <StackPanel x:Name="Fld_Uuid">
                            <TextBlock Text="UUID" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MUuid" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel x:Name="Fld_Username" Visibility="Collapsed">
                            <TextBlock Text="Username (optional)" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MUser" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel x:Name="Fld_Password">
                            <TextBlock Text="Password" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MPassword" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel x:Name="Fld_Method">
                            <TextBlock Text="Cipher" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <ComboBox x:Name="MMethod" Style="{StaticResource FormCombo}">
                                <sys:String>aes-256-gcm</sys:String>
                                <sys:String>aes-128-gcm</sys:String>
                                <sys:String>chacha20-ietf-poly1305</sys:String>
                                <sys:String>chacha20-poly1305</sys:String>
                                <sys:String>2022-blake3-aes-256-gcm</sys:String>
                                <sys:String>2022-blake3-chacha20-poly1305</sys:String>
                                <sys:String>none</sys:String>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel x:Name="Fld_Flow">
                            <TextBlock Text="Flow (optional)" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MFlow" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel x:Name="Fld_Wg" Visibility="Collapsed">
                            <TextBlock Text="Private key" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MWgPrivate" Style="{StaticResource FormInput}"/>
                            <TextBlock Text="Peer public key" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MWgPublic" Style="{StaticResource FormInput}"/>
                            <TextBlock Text="Pre-shared key (optional)" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MWgPsk" Style="{StaticResource FormInput}"/>
                            <TextBlock Text="Address (e.g. 10.0.0.2/32)" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MWgAddress" Style="{StaticResource FormInput}"/>
                            <TextBlock Text="MTU" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MWgMtu" Style="{StaticResource FormInput}"/>
                            <TextBlock Text="Reserved (optional, e.g. 1,2,3)" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MWgReserved" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <TextBlock x:Name="TransportLabel" Text="Transport" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                        <ComboBox x:Name="MNetwork" Style="{StaticResource FormCombo}" SelectionChanged="FieldSel_Changed">
                            <sys:String>tcp</sys:String>
                            <sys:String>ws</sys:String>
                            <sys:String>grpc</sys:String>
                            <sys:String>http</sys:String>
                            <sys:String>quic</sys:String>
                            <sys:String>kcp</sys:String>
                            <sys:String>httpupgrade</sys:String>
                            <sys:String>xhttp</sys:String>
                        </ComboBox>
                        <StackPanel x:Name="Fld_HeaderType">
                            <TextBlock Text="Header type" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <ComboBox x:Name="MHeaderType" Style="{StaticResource FormCombo}">
                                <sys:String>none</sys:String>
                                <sys:String>http</sys:String>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel x:Name="Fld_Path">
                            <TextBlock Text="Path / seed" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MPath" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel x:Name="Fld_Host">
                            <TextBlock Text="Host header" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MHost" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel x:Name="Fld_ServiceName">
                            <TextBlock Text="gRPC service name" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MServiceName" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel x:Name="Fld_Mode">
                            <TextBlock Text="Mode (grpc: gun/multi, xhttp)" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MMode" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <TextBlock x:Name="SecurityLabel" Text="Security" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                        <ComboBox x:Name="MSecurity" Style="{StaticResource FormCombo}" SelectionChanged="FieldSel_Changed">
                            <sys:String>none</sys:String>
                            <sys:String>tls</sys:String>
                            <sys:String>reality</sys:String>
                        </ComboBox>
                        <StackPanel x:Name="Fld_Sni">
                            <TextBlock Text="SNI / server name" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MSni" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel x:Name="Fld_Alpn">
                            <TextBlock Text="ALPN" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <ComboBox x:Name="MAlpn" Style="{StaticResource FormCombo}">
                                <sys:String>none</sys:String>
                                <sys:String>h2,http/1.1</sys:String>
                                <sys:String>h2</sys:String>
                                <sys:String>http/1.1</sys:String>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel x:Name="Fld_Fingerprint">
                            <TextBlock Text="Fingerprint" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <ComboBox x:Name="MFingerprint" Style="{StaticResource FormCombo}">
                                <sys:String>chrome</sys:String>
                                <sys:String>firefox</sys:String>
                                <sys:String>safari</sys:String>
                                <sys:String>ios</sys:String>
                                <sys:String>android</sys:String>
                                <sys:String>edge</sys:String>
                                <sys:String>random</sys:String>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel x:Name="Fld_Pbk">
                            <TextBlock Text="Public key (reality pbk)" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MPbk" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel x:Name="Fld_Sid">
                            <TextBlock Text="Short ID (reality sid)" Foreground="#9FB3D6" FontSize="13" Margin="11,0,0,4"/>
                            <TextBox x:Name="MSid" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <TextBlock x:Name="MError" Foreground="#E57373" FontSize="12" Margin="0,0,0,4"/>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource LiveButton}" Grid.Column="0" Content="{DynamicResource Str.cancel}" Click="CloseManual"
                            Height="44" Margin="0,0,6,0" Background="#24406F" Foreground="White" FontSize="14" FontWeight="SemiBold" FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend SemiBold, Segoe UI" BorderThickness="0" Cursor="Hand"/>
                    <Button Style="{StaticResource LiveButton}" Grid.Column="1" Content="{DynamicResource Str.save}" Click="ManualSave_Click"
                            Height="44" Margin="6,0,0,0" Background="#3D6AD6" Foreground="White" FontSize="14" FontWeight="SemiBold" FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend SemiBold, Segoe UI" BorderThickness="0" Cursor="Hand"/>
                </Grid>
            </Grid>

            <Grid x:Name="UsagePanel" Visibility="Collapsed" VerticalAlignment="Top">
                <ScrollViewer Style="{StaticResource EdgeShift}" x:Name="UsageScroll" VerticalScrollBarVisibility="Auto" CanContentScroll="False" FocusVisualStyle="{x:Null}">
                    <StackPanel>
                        <Border Background="#0E1A38" CornerRadius="12" Padding="16" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{DynamicResource Str.usage_all_time}" Foreground="#9FB3D6" FontSize="12"/>
                                    <TextBlock x:Name="AllTimeText" Foreground="#5B83D6" FontSize="22" FontWeight="Bold" FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend Bold, Segoe UI"
                                               FlowDirection="LeftToRight"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" x:Name="TopConfigBox" VerticalAlignment="Center" HorizontalAlignment="Right" Visibility="Collapsed">
                                    <TextBlock Text="{DynamicResource Str.usage_most_used}" Foreground="#9FB3D6" FontSize="11.5" HorizontalAlignment="Right"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,0,0" FlowDirection="LeftToRight">
                                        <Rectangle x:Name="TopConfigFlag" Width="20" Height="15" RadiusX="3" RadiusY="3"
                                                   VerticalAlignment="Center" Margin="0,0,7,0" SnapsToDevicePixels="True" Visibility="Collapsed">
                                            <Rectangle.Fill>
                                                <ImageBrush x:Name="TopConfigFlagBrush" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <TextBlock x:Name="TopConfigName" Foreground="#DCE6F5" FontSize="14" FontWeight="SemiBold"
                                                   FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend SemiBold, Segoe UI"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="170"/>
                                    </StackPanel>
                                    <TextBlock x:Name="TopConfigUsage" Foreground="#6E9CF0" FontSize="12.5" FlowDirection="LeftToRight"
                                               FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend, Segoe UI" HorizontalAlignment="Right" Margin="0,1,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Margin="0,0,0,12" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="10" Background="#0E1F40" BorderBrush="#284372" BorderThickness="1" Padding="4"
                                    HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="RangeToday" GroupName="UsageRange" Style="{StaticResource SegRadio}"
                                                 Content="{DynamicResource Str.range_today}" Click="Range_Today" IsChecked="True" Margin="0,0,3,0"/>
                                    <RadioButton x:Name="RangeWeek" GroupName="UsageRange" Style="{StaticResource SegRadio}"
                                                 Content="{DynamicResource Str.range_7d}" Click="Range_Week" Margin="0,0,3,0"/>
                                    <RadioButton x:Name="RangeMonth" GroupName="UsageRange" Style="{StaticResource SegRadio}"
                                                 Content="{DynamicResource Str.range_30d}" Click="Range_Month" Margin="0,0,3,0"/>
                                    <RadioButton x:Name="RangeCustom" GroupName="UsageRange" Style="{StaticResource SegRadio}"
                                                 Content="{DynamicResource Str.range_custom}" Click="Range_Custom"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" CornerRadius="10" Background="#0E1A38" BorderBrush="#22345B" BorderThickness="1"
                                    Padding="12,7" Width="176" Margin="12,0,0,0" VerticalAlignment="Stretch">
                                <StackPanel VerticalAlignment="Center" FlowDirection="LeftToRight">
                                    <Grid Margin="0,0,0,3">
                                        <TextBlock Text="{DynamicResource Str.usage_download}" Foreground="#9FB3D6" FontSize="12.5"
                                                   FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend, Segoe UI" HorizontalAlignment="Left"/>
                                        <TextBlock x:Name="UsageDownText" Foreground="#DCE6F5" FontSize="12.5" FontWeight="SemiBold"
                                                   FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend SemiBold, Segoe UI" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="{DynamicResource Str.usage_upload}" Foreground="#9FB3D6" FontSize="12.5"
                                                   FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend, Segoe UI" HorizontalAlignment="Left"/>
                                        <TextBlock x:Name="UsageUpText" Foreground="#DCE6F5" FontSize="12.5" FontWeight="SemiBold"
                                                   FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend SemiBold, Segoe UI" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <StackPanel x:Name="CustomDates" Orientation="Horizontal" Margin="0,0,0,10" Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource Str.usage_from}" Foreground="#9FB3D6" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <DatePicker x:Name="FromDate" Width="130" Margin="0,0,12,0" SelectedDateChanged="CustomDateChanged"
                                        Style="{StaticResource ThemeDatePicker}" CalendarStyle="{StaticResource ThemeCalendar}"/>
                            <TextBlock Text="{DynamicResource Str.usage_to}" Foreground="#9FB3D6" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <DatePicker x:Name="ToDate" Width="130" SelectedDateChanged="CustomDateChanged"
                                        Style="{StaticResource ThemeDatePicker}" CalendarStyle="{StaticResource ThemeCalendar}"/>
                        </StackPanel>

                        <TextBlock x:Name="NoDataText" Text="{DynamicResource Str.usage_no_data}" Foreground="#9FB3D6"
                                   FontSize="13" Visibility="Collapsed" Margin="0,6,0,0"/>
                        <Border Background="#0E1A38" CornerRadius="12" Padding="12,14,12,12" Margin="0,4,0,0">
                            <StackPanel>
                                <Grid x:Name="ChartGrid" Height="150"/>
                                <Canvas x:Name="LabelCanvas" Height="18" Margin="0,4,0,0" SizeChanged="LabelCanvas_SizeChanged"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="{DynamicResource Str.usage_hint}" Foreground="#9FB3D6" FontSize="11"
                                   Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="ToolsPanel" Visibility="Collapsed" VerticalAlignment="Top">
                <ScrollViewer Style="{StaticResource EdgeShift}" x:Name="ToolsScroll" VerticalScrollBarVisibility="Auto" CanContentScroll="False" FocusVisualStyle="{x:Null}">
                <StackPanel>
                    <Border Style="{StaticResource ToolCard}">
                        <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Path Data="M12 2 L2 7 L12 12 L22 7 Z M2 12 L12 17 L22 12 M2 17 L12 22 L22 17" Stroke="#6E9CF0" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Fill="Transparent" Width="17" Height="17" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,9,0"/>
                            <TextBlock Text="{DynamicResource Str.geo_files}" Foreground="White" FontSize="14.5" FontWeight="SemiBold"
                                       FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend SemiBold, Segoe UI" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="74"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
