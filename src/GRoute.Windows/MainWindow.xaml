                                        <RadioButton x:Name="LogWarning" GroupName="LogLevel" Style="{StaticResource SegRadio}" Content="{DynamicResource Str.log_warning}" Tag="warning" Click="LogLevel_Set" IsChecked="True" Margin="0,0,3,0"/>
                                        <RadioButton x:Name="LogInfo" GroupName="LogLevel" Style="{StaticResource SegRadio}" Content="{DynamicResource Str.log_info}" Tag="info" Click="LogLevel_Set" Margin="0,0,3,0"/>
                                        <RadioButton x:Name="LogDebug" GroupName="LogLevel" Style="{StaticResource SegRadio}" Content="{DynamicResource Str.log_debug}" Tag="debug" Click="LogLevel_Set"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="2,2,0,0">
                            <Path Data="M8 1.5 A6.5 6.5 0 1 1 7.99 1.5 M8 7.2 V11.3 M8 4.6 V4.9" Stroke="#6E7DA0" StrokeThickness="1.4"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Width="14" Height="14" Stretch="Uniform"
                                  VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="{DynamicResource Str.takes_effect}" Foreground="#8093B5" FontSize="11.5" VerticalAlignment="Center"
                                       FontFamily="pack://application:,,,/GRoute;component/Fonts/#Lexend, Segoe UI"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Grid>
        <Grid x:Name="MenuOverlay" Grid.Row="1" Visibility="Collapsed">
            <Border x:Name="MenuScrim" Background="#000000" Opacity="0" MouseLeftButtonUp="CloseMenu_Click"/>
