                </Border.Effect>
                <StackPanel>
                    <Border x:Name="DialogIconTile" Width="44" Height="44" CornerRadius="12" Background="#16264A" HorizontalAlignment="Left" Margin="0,0,0,16">
                        <Path x:Name="DialogIcon" Data="M21 2v6h-6 M3 12a9 9 0 0 1 15-6.7L21 8 M3 22v-6h6 M21 12a9 9 0 0 1-15 6.7L3 16"
                              Stroke="#6E9CF0" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Fill="Transparent" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="DialogTitle" Text="GRoute" Foreground="White" FontSize="16" FontWeight="Bold"
