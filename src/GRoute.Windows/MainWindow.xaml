                                                                      Fill="Transparent" Width="17" Height="17" Stretch="Uniform"/>
                                                            </Button>
                                                            <Button Grid.Column="3" Style="{StaticResource IconAction}" Tag="{Binding Id}" ToolTip="{DynamicResource Str.copy}"
                                                                    Click="CopyConfig_Click" VerticalAlignment="Center" BorderBrush="#3D6AD6">
                                                                <Path Data="M20 9h-9a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2v-9a2 2 0 0 0-2-2z M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" Stroke="#6E9CF0" StrokeThickness="1.8"
                                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                                      Fill="Transparent" Width="17" Height="17" Stretch="Uniform"/>
                                                            </Button>
                                                            <Button Grid.Column="4" Style="{StaticResource IconAction}" Tag="{Binding Id}" ToolTip="{DynamicResource Str.delete}"
                                                                    Click="DeleteServer_Click" VerticalAlignment="Center" BorderBrush="#E0575C">
                                                                <Path Data="M3 6h18 M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 M10 11v6 M14 11v6" Stroke="#E57373" StrokeThickness="1.8"
                                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                                      Fill="Transparent" Width="17" Height="17" Stretch="Uniform"/>
                                                            </Button>
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <Trigger SourceName="CfgBox" Property="IsMouseOver" Value="True">
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard><Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="CfgHover" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.16"/>
                                                                </Storyboard></BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard><Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="CfgHover" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.22"/>
                                                                </Storyboard></BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="HeaderBox" Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard><Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverFill" Storyboard.TargetProperty="Opacity" To="0.6" Duration="0:0:0.18"/>
                                            </Storyboard></BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard><Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverFill" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.24"/>
